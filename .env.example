# Supabase — project ref: xcidbfgujrxginrgvbjw
NEXT_PUBLIC_SUPABASE_URL=https://xcidbfgujrxginrgvbjw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Bug Reporter (JKKN Bug Boundary) — register the app on the platform, then paste
# the real values here (the platform issues a key like br_xxxx). The widget stays
# inactive while either value still contains REPLACE_ME.
NEXT_PUBLIC_BUG_REPORTER_API_KEY=br_REPLACE_ME
NEXT_PUBLIC_BUG_REPORTER_API_URL=https://bug-reporter.REPLACE_ME
